# =====================================================================
# DocTranslate Enterprise Configuration File (.env)
# =====================================================================

# 1. Flask Web Application Security Configuration
FLASK_SECRET=dev-secret-key-1337-enterprise

# 2. Pluggable Translation Engine Credentials
# If these keys are left empty, the application gracefully activates
# its high-fidelity simulated engines with active cost billing.

# Google Cloud Translation API Key
GOOGLE_API_KEY=

# DeepL Pro API Authentication Key
DEEPL_API_KEY=

# Microsoft Azure Translator API Key & Region
AZURE_API_KEY=
AZURE_API_REGION=global

# LibreTranslate Offline Local Endpoint URL
# Default fallback is the public instance or local server http://localhost:5000/
LIBRETRANSLATE_API_URL=http://localhost:5000/

# 3. Enterprise Notification Workflow Settings (SMTP Email Server)
# Complete these settings to allow DocTranslate to send actual emails.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=no-reply@doctranslate.com

# 4. MySQL Database Configuration
MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=doctranslate
